# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase, Neon, Railway, or any Postgres provider
DATABASE_URL="postgresql://user:password@host:5432/bespoke_bike_tours"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Get from Stripe dashboard → Webhooks (needed for payment confirmation)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from https://resend.com
RESEND_API_KEY="re_..."
EMAIL_FROM="Bespoke Bike Tours Boston <hello@bespokebikeboston.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Seed ─────────────────────────────────────────────────────────────────────
ADMIN_SEED_PASSWORD="changeme-set-a-real-password"
